{
  "name": "raptorxilef/php-js-dev-env-blueprint",
  "description": "Testumgebung meiner NPM/package.json Einstellungen",
  "type": "project",
  "license": "CC-BY-NC-SA-4.0",
  "authors": [
    {
      "name": "Felix Maywald",
      "email": "31962607+RaptorXilef@users.noreply.github.com"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-zip": "*",
    "ext-mbstring": "*",
    "vlucas/phpdotenv": "^5.6",
    "ezyang/htmlpurifier": "^4.19"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
    "deptrac/deptrac": "^4.6",
    "friendsofphp/php-cs-fixer": "^3.95",
    "kubawerlos/php-cs-fixer-custom-fixers": "^3.37",
    "pestphp/pest": "^4.6",
    "phpcompatibility/php-compatibility": "^10.0@alpha",
    "phpcsstandards/phpcsextra": "^1.5",
    "phpcsstandards/phpcsutils": "^1.2",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5",
    "rector/rector": "^2.4",
    "slevomat/coding-standard": "^8.28",
    "squizlabs/php_codesniffer": "^4.0",
    "phpmd/phpmd": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "vendor-dir": "vendor/",
    "optimize-autoloader": true,
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "pestphp/pest-plugin": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "// --- PHASE 0: SETUP & LIFECYCLE ---": "Initialisierung und Bereinigung",
    "collect": "pwsh.exe -ExecutionPolicy Bypass -Command \"& (Get-Item scripts/Collect-All*.ps1).FullName\"",
    "setup": "@php scripts/Setup.php init",
    "clear": "@php scripts/Setup.php clear",
    "//post-install-cmd": "@setup",
    "//post-update-cmd": "@setup",
    "post-autoload-dump": "@setup",

    "// --- PHASE 1: STATIC ANALYSIS (CHECKING) ---": "Read-Only Qualitätsprüfungen",
    "chk:stan": "phpstan analyse --memory-limit=2G",
    "chk:stan-baseline": "phpstan analyse --generate-baseline",
    "chk:cs": "phpcs",
    "chk:style": "php-cs-fixer fix --dry-run --diff --no-interaction",
    "chk:md": "phpmd analyze src --format text --ruleset phpmd.xml.dist",
    "chk:cpd": "php -d display_errors=0 tools/phpcpd.phar src/ --min-lines=5 --min-tokens=70",
    "chk:arch": "deptrac analyse --config-file=deptrac.yaml",
    "chk:modern": "rector process --dry-run",

    "// --- PHASE 2: TESTING ---": "Automatisierte Tests",
    "test": "pest --parallel",
    "test:full": "pest --parallel --display-deprecations",
    "test:coverage": "XDEBUG_MODE=coverage pest --coverage --coverage-html .build/reports/phpunit-html",
    "test:mutation": "php -d xdebug.mode=coverage tools/infection.phar --threads=4 --min-msi=30 --coverage=.cache/phpunit",
    "//test:phpunit": "phpunit",
    "//test:unit": "phpunit --testsuite Unit",
    "//test:feature": "phpunit --testsuite Feature",
    "//test:legacy-coverage": "XDEBUG_MODE=coverage phpunit --coverage-html .build/reports/phpunit-html",

    "// --- PHASE 3: FIXING & FORMATTING ---": "Aktive Code-Manipulation",
    "fix:cs": "phpcbf",
    "fix:style": "php-cs-fixer fix --allow-risky=yes",
    "fix:modern": "rector process",

    "// --- PHASE 4: CI / AUTOMATION ---": "Spezifische Reports für Pipelines",
    "mkdir:reports": "@php -r \"is_dir('.build/reports') || mkdir('.build/reports', 0777, true);\"",
    "ci:phpstan": [
      "@mkdir:reports",
      "phpstan analyse --error-format=checkstyle --no-progress > .build/reports/phpstan.xml || true"
    ],
    "ci:test": ["@mkdir:reports", "pest --ci --log-junit .build/reports/junit.xml"],
    "ci:cs": [
      "@mkdir:reports",
      "phpcs --report=checkstyle --report-file=.build/reports/phpcs.xml || true"
    ],
    "ci:md": [
      "@mkdir:reports",
      "phpmd analyze src --format xml --ruleset phpmd.xml.dist --reportfile-xml .build/reports/phpmd.xml || true"
    ],

    "// --- PHASE 5: MAINTENANCE & UTILS ---": "Hilfswerkzeuge",
    "util:up": "@php scripts/Setup.php up",
    "util:dump": "composer dump-autoload -o",
    "util:pkg-up": ["npm audit fix", "composer update", "@util:up"],

    "// --- MASTER COMMANDS ---": "Zusammengefasste Workflows",
    "chk": ["@qa"],
    "fix": ["@fmt", "@fix:cs"],
    "fmt": ["@fix:modern", "@fix:style"],
    "qa": [
      "@chk:style",
      "@chk:cs",
      "@chk:md",
      "@chk:cpd",
      "@chk:arch",
      "@chk:modern",
      "@chk:stan",
      "@test"
    ],
    "qa:full": ["@qa", "@test:mutation"]
  }
}
