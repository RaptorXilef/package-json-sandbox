{
  "name": "@raptorxilef/package-json-sandbox",
  "version": "0.19.0",
  "description": "Testumgebung meiner NPM/package.json Einstellungen",
  "type": "module",
  "author": "Felix Maywald",
  "license": "CC-BY-NC-SA-4.0",
  "engines": {
    "node": ">=25.3.0",
    "npm": ">=11.11.0"
  },
  "scripts": {
    "// --- 0:.Collect ---": "",
    "collect": "pwsh.exe -ExecutionPolicy Bypass -Command \"& (Get-Item scripts/Collect-All*.ps1).FullName\"",
    "collect-info": "pwsh.exe -Command \"Get-Location; Get-ChildItem scripts\"",
    "// --- 1. DEVELOPMENT ---": "Befehle für die tägliche Arbeit",
    "dev": "vite --host",
    "images:optimize": "node scripts/optimize-images.js",
    "preview": "vite preview",
    "prepare": "husky",
    "// --- LEGACY TRANSITION (Non-Vite) ---": "",
    "legacy:css:watch": "sass --watch src/scss:public/assets/css --style=expanded --source-map",
    "legacy:css:build": "sass src/scss:public/assets/css --style=compressed --no-source-map",
    "legacy:js:build": "node scripts/legacy-minify-js.js",
    "legacy:build": "npm run legacy:css:build && npm run legacy:js:build",
    "// --- 2. TESTING ---": "Unit-Tests und Test-Runner",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "node_test": "node --test",
    "// --- 3. LINTING & FIXING ---": "Statische Code-Analyse",
    "lint:all": "npm run biome:check && npm run lint:css && npm run lint:html && npm run lint:spell && npm run lint:md",
    "fix": "npm run biome:fix && npm run lint:css:fix",
    "biome:check": "biome check --write .",
    "biome:fix": "biome check --fix .",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint .",
    "lint:css": "stylelint \"**/*.scss\"",
    "lint:css:fix": "stylelint \"**/*.scss\" --fix",
    "lint:spell": "cspell lint \"**\" --no-progress --show-suggestions",
    "lint:md": "markdownlint-cli2",
    "lint:html": "markuplint \"**/*.html\"",
    "// --- 4. ACCESSIBILITY (A11Y) ---": "Barrierefreiheits-Checks",
    "lint:a11y": "axe public/index.html",
    "lint:a11y:url": "axe http://localhost/package-json-sandbox",
    "ci:lint:a11y": "axe --ci --tags wcag2a,wcag2aa http://localhost:3000",
    "// --- 5. BUILD ---": "Erstellung der Produktions-Assets",
    "build": "vite build",
    "// --- 6. RELEASE-MANAGEMENT ---": "Versionierung und Changelogs",
    "release": "release-it",
    "release:alpha": "release-it --preRelease=alpha",
    "release:beta": "release-it --preRelease=beta",
    "release:rc": "release-it --preRelease=rc",
    "release:patch": "release-it --increment=patch --ci",
    "release:init": "release-it --first-release",
    "release:show_token": "echo $GITHUB_TOKEN",
    "ci:release:test": "release-it --dry-run --ci",
    "changelog:rebuild": "conventional-changelog --config changelog-config.js -i CHANGELOG.md -s -r 0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.2",
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cspell/dict-de-de": "^4.1.2",
    "@markuplint/html-spec": "^4.18.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@vitest/ui": "^4.1.5",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cspell": "^10.0.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.1",
    "markuplint": "^4.18.1",
    "release-it": "^20.0.1",
    "sass-embedded": "^1.99.0",
    "sharp": "^0.34.5",
    "stylelint": "^17.9.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "terser": "^5.46.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ],
  "lint-staged": {
    "// *.php": [
      "vendor/bin/phpcs",
      "vendor/bin/phpstan analyze"
    ],
    "*.json": "biome check --write --no-errors-on-unmatched",
    "*.js": [
      "biome check --write --no-errors-on-unmatched",
      "vitest related --run"
    ],
    "*.scss": "stylelint --fix",
    "*.html": "markuplint",
    "*.md": "markdownlint-cli2 --fix",
    "*": "cspell lint --no-must-find-files --no-progress"
  }
}
