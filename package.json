{
  "name": "@raptorxilef/package-json-sandbox",
  "version": "0.5.0",
  "description": "Testumgebung meiner NPM/package.json Einstellungen",
  "type": "module",
  "author": "Felix Maywald",
  "license": "CC-BY-NC-SA-4.0",
  "engines": {
    "node": ">=25.3.0",
    "npm": ">=11.11.0"
  },
  "scripts": {
    "test": "node --test",
    "// --- RELEASE-MANAGEMENT ---": "",
    "release": "release-it",
    "release:alpha": "release-it --preRelease=alpha",
    "release:beta": "release-it --preRelease=beta",
    "release:rc": "release-it --preRelease=rc",
    "release:patch": "release-it --increment=patch --ci",
    "ci:release:test": "release-it --dry-run --ci",
    "release:init": "release-it --first-release",
    "changelog:rebuild": "conventional-changelog --config changelog-config.js -i CHANGELOG.md -s -r 0",
    "release:show_token": "echo $GITHUB_TOKEN",
    "// --- COMMIT-KONTROLLE-HUSKY ---": "",
    "prepare": "husky",
    "// --- LINTER-BIOME ---": "",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint .",
    "biome:check": "biome check --write .",
    "biome:fix": "biome check --fix .",
    "// --- LINT ---": "",
    "lint:css": "stylelint \"**/*.scss\"",
    "lint:css:fix": "stylelint \"**/*.scss\" --fix",
    "// --- LINT SPELL ---": "",
    "lint:spell": "cspell lint \"**\" --no-progress --show-suggestions",
    "// --- LINT MARKDOWN ---": "",
    "lint:md": "markdownlint-cli2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cspell/dict-de-de": "^4.1.2",
    "@markuplint/html-spec": "^4.18.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cspell": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.1",
    "markuplint": "^4.18.1",
    "release-it": "^20.0.1",
    "stylelint": "^17.9.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1"
  },
  "overrides": {},
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ],
  "lint-staged": {
    "*.php": [
      "vendor/bin/phpcs",
      "vendor/bin/phpstan analyze"
    ],
    "*.{js,json}": "biome check --write --no-errors-on-unmatched",
    "*.scss": "stylelint --fix",
    "*.html": "markuplint",
    "*.md": "markdownlint-cli2 --fix",
    "*": "cspell lint --no-must-find-files --no-progress"
  }
}
