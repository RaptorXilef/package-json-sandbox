# =============================================================================
# PHPStan Konfiguration für High-End Code-Qualität
# =============================================================================

includes:
    # WICHTIG: Bleeding Edge muss unter 'includes' stehen, nicht bei bootstrapFiles.
    # Aktiviert die neuesten, striktesten Analysen (z.B. Dead Code Detection).
    - vendor/phpstan/phpstan/conf/bleedingEdge.neon
    - phpstan-baseline.neon
    # - vendor/phpstan/phpstan-phpunit/extension.neon # (macht jetzt der installer)
    # - vendor/phpstan/phpstan-strict-rules/rules.neon # (macht jetzt der installer)

parameters:
    # Level 0-9
    # Level 5 prüft Typen, erlaubt aber noch etwas Flexibilität.
    # Level 9 wäre "Maximaler Schmerz" (nur für neue Projekte empfohlen).
    # TODO: Vor release auf "max" setzen ohne "
    level: 6

    # Welche Ordner sollen analysiert werden?
    paths:
        - src
        - tests
        - public
        - bootstrap
        - config

    # Exklusionen (Vendor und Node_Modules sollten ignoriert werden)
    excludePaths:
        analyse:
            - vendor
            - node_modules
            - public/dist
            - '**/.debug/**'

    # Wir simulieren eine PHP 8.4 Umgebung (80400), damit PHPStan
    # neue Features (wie Property Hooks) bereits jetzt versteht.
    phpVersion: 80400

    # Cache beschleunigt die Analyse massiv
    tmpDir: .cache/phpstan

    # Nutzt alle Kerne (Parallelisierung)
    parallel:
        processTimeout: 300.0

    # Prüft, ob Funktionen Seiteneffekte haben (Clean Code)
    rememberPossiblyImpureFunctionValues: true

    # Meldet, wenn du einen Fehler ignorierst, der gar nicht mehr existiert
    reportUnmatchedIgnoredErrors: true

    # Dies verhindert, dass PHPStan denkt, er wüsste es besser als die Laufzeit,
    # wenn es um native Funktionen geht, die false liefern können.
    treatPhpDocTypesAsCertain: false
