{
    "extends": [
        "markuplint:recommended"
    ],
    "rules": {
        "invalid-attr": true,
        "doctype": "always",
        "permitted-contents": true
    },
    "nodeRules": [
        {
            "selector": "img",
            "rules": {
                "required-attr": [
                    "alt"
                ]
            }
        }
    ]
}
