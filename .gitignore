# ==============================================================================
# SYSTEM & OS DATEIEN
# ==============================================================================
# Mac
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# Linux (temporäre Dateien)
*~

# ==============================================================================
# IDEs & EDITOREN
# ==============================================================================
# JetBrains (PhpStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws

# VS Code
#.vscode/
#*.code-workspace
.history/

# Andere Editoren (Sublime, Atom, NetBeans, Eclipse)
*.sublime-project
*.sublime-workspace
.nbproject/
.settings/
.buildpath
.project

# ==============================================================================
# GENERELLE BACKUPS & TEMPORÄRE DATEIEN
# ==============================================================================
*.log
*.tmp
*.temp
*.swp
*.swo
*backup*
*Backup*
* - Kopie*
.testfiles/
/data/tmp/*

# ==============================================================================
# SICHERHEIT & LOKALE KONFIGURATION
# ==============================================================================
# WICHTIG: Niemals .env Dateien mit echten Zugangsdaten committen!
.env
.env.local
.env.*.local
# Ausnahme: .env.example sollte oft versioniert werden, damit andere wissen, welche Variablen benötigt werden.
!/.env.example

# SSL Zertifikate (falls lokal abgelegt)
*.pem
*.key
*.crt

# ==============================================================================
# PHP & COMPOSER
# Composer-Abhängigkeiten
# Composer dependencies
# ==============================================================================
/vendor/

# Composer:
# composer.lock sollte in ANWENDUNGEN normalerweise committed werden,
# um konsistente Installs zu garantieren. In LIBRARIES wird es oft ignoriert.
# Wenn du sicher bist, dass du es ignorieren willst, lass die nächste Zeile aktiv:

# - `composer.lock` aus der `.gitignore` entfernt und dem Repository hinzugefügt.
# - Dies ist notwendig, damit Caching funktioniert.
#/composer.lock
/composer.phar

# Builds, Logs und Cache
/build/
/log/
/logs/

# Cache & Logs
/.cache/
!.gitkeep

.cache/php-cs-fixer/cache.json

/.phpstan.cache/
.phpcs.cache

# PHPUnit & Testing
.phpunit.result.cache
/.phpunit.cache/
/phpunit.xml
# Alternativ: phpunit.xml.dist versionieren, phpunit.xml ignorieren (für lokale Overrides)

.lighthouseci/*

# Code Coverage Reports
/coverage/
/html-coverage/

# ==============================================================================
# DATENBANK DUMPS (Lokal)
# ==============================================================================
*.sql
*.sqlite
*.sqlite3

# ==============================================================================
# FRONTEND (Node, npm, yarn)
# ==============================================================================
/node_modules/
npm-debug.log*
yarn-error.log
yarn.lock

# - `package-lock.json` aus der `.gitignore` entfernt und dem Repository hinzugefügt.
# - Dies ist notwendig, damit `npm ci` in der CI/CD-Pipeline deterministische Builds durchführen kann und Caching funktioniert.
#package-lock.json

# Hinweis: package-lock.json / yarn.lock sollten ähnlich wie composer.lock
# meistens committed werden, wenn es sich um eine Endanwendung handelt.


# ------------------------------------------------------------------------------
# Generierte Assets (aus resources/scss & resources/js)
# ------------------------------------------------------------------------------
# ENTSCHEIDUNG ERFORDERLICH:
# Wenn auf dem Live-Server KEINEN Build-Prozess (npm run build etc.) ist,
# müssen die folgenden Zeilen mit '#' auskommentieren, damit die fertigen
# CSS/JS Dateien im Repository landen!
#
# /public/assets/css/
# /public/assets/js/
# /public/build/

# SCSS / Sass Cache
.sass-cache/
*.css.map

# Minifizierte Dateien (generell)
# *.min.css
# *.min.js
# *.min.js.map

# ------------------------------------------------------------------------------
# Passwörter und Geheimnisse
# Geheime Konfiguration (enthält Passwörter/Schlüssel)
# Secret configuration (contains passwords/keys)
# ------------------------------------------------------------------------------
/config/secret.php
/storage/


# ------------------------------------------------------------------------------
# Anwendungs-Log-Dateien (Sicherheit, Debugging)
# Application log files (security, debugging)
# ------------------------------------------------------------------------------
logs/

# ==============================================================================
# REMOVE & DEPRECATED
# ==============================================================================
*_deprecated*
*_remove*
*_DEPRECATED*
*_REMOVE*


# ==============================================================================
# PROJEKT SPEZIFISCH
# ==============================================================================

# Composer-Abhängigkeiten
/kga-core/vendor/

# Sensible Daten & Konfiguration
/kga-core/config/config.php
/kga-core/storage/daten.json
/kga-core/storage/*.json

/public/assets/css/*.map
/public/assets/js/*.map

# Generierte Frontend-Assets (Build-Artefakte)
# Wir vertrauen unserem Build-Prozess (npm run make)
/public/assets/css/*
/public/assets/js/*
!/public/assets/css/.gitkeep
!/public/assets/js/.gitkeep

# Infrastruktur & Tools (werden via scripts/Setup.php verwaltet)
/tools/*.phar
/.build/

# Temporäre Zip-Archive & OS-Reste
*.zip
*.7z
*.ink
*.url

# Private Scripte & Notizen (Sicherheit geht vor)
/.debug/*
Combine-*.ps1
Mein*Code*.*
Refactored_PHP_Code_Part*
*Notizen*
.*todo*
ToDo*.md
*Commites*
*.docx
*.txt
*.psd

.npmrc

# AUSNAHMEN (Diese Dateien MÜSSEN im Repo bleiben)
!composer.lock
!package-lock.json
!cspell-words.txt
