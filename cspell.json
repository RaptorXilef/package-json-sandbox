{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en,de",
  "useGitignore": true,
  "import": ["@cspell/dict-de-de/cspell-ext.json"],
  "dictionaryDefinitions": [
    {
      "name": "general-words",
      "path": "./cspell-general.txt",
      "addWords": true
    },
    {
      "name": "project-words",
      "path": "./cspell-project.txt",
      "addWords": true
    },
    {
      "name": "denglisch-words",
      "path": "./cspell-denglisch.txt",
      "addWords": true
    },
    {
      "name": "proper-names",
      "path": "./cspell-proper-names.txt",
      "addWords": true
    },
    {
      "name": "tech-terms",
      "path": "./cspell-technical.txt",
      "addWords": true
    },
    {
      "name": "folder-names",
      "path": "./cspell-folder-names.txt",
      "addWords": true
    }
  ],
  "dictionaries": [
    "en_US",
    "de-de",
    "softwareTerms",
    "php",
    "node",
    "html",
    "css",
    "bash",
    "npm",
    "misc",
    "general-words",
    "project-words",
    "denglisch-words",
    "proper-names",
    "tech-terms",
    "folder-names"
  ],
  "ignorePaths": [
    "node_modules/**",
    "vendor/**",
    "public/assets/**",
    "CHANGELOG.md",
    "package-lock.json",
    ".gitignore",
    "*.min.*"
  ]
}
