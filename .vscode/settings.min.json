{
  // --- FORMATIERUNG ---
  "editor.formatOnSave": true,
  "files.eol": "\n",
  "editor.rulers": [120],
  "rewrap.wrappingColumn": 120,

  // --- PHP (PHPSAB ist der Chef) ---
  "[php]": {
    "editor.defaultFormatter": "valeryanm.vscode-phpsab",
    "editor.formatOnSave": true
  },
  "phpsab.snifferEnable": true,
  "phpsab.fixerEnable": true,
  "phpsab.standard": "", // Nutzt automatisch die phpcs.xml.dist im Root
  "intelephense.format.enable": false, // Deaktiviert, um Konflikte mit PHPCBF zu vermeiden

  // --- FRONTEND (Prettier & Linter) ---
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": { "source.fixAll.stylelint": "explicit" }
  },

  // --- SUCHE & PERFORMANCE ---
  "files.exclude": {
    "**/vendor/": true,
    "**/node_modules/": true,
    "**/.cache/": true,
    "**/.build/": true,
    "**/*.map": true
  },
  "files.watcherExclude": {
    "**/vendor/**": true,
    "**/node_modules/**": true
  },

  // --- TOOLS ---
  "cSpell.language": "en,de",
  "todo-tree.general.tags": ["BUG", "HACK", "FIXME", "TODO", "VOR_RELEASE"],
  "terminal.integrated.defaultProfile.windows": "Git Bash"
}
